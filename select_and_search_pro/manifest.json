{
  "manifest_version": 3,
  "name": "Select and Search Pro",
  "version": "2.0.8",
  "description": "Select text to copy, search, ask AI, or forward links. Quick toolbar + right-click menu Search.",
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://gemini.google.com/*"
      ],
      "js": ["ai-content.js"],
      "run_at": "document_end"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "options.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
